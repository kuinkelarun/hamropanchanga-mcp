# Firebase Admin SDK credentials — one of:
#   (a) Path to a service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
#   (b) Inline JSON (preferred for Railway / hosted deploys)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

FIREBASE_PROJECT_ID=hamropanchanga
FIREBASE_DATABASE_ID=hamropanchanga-db

# Phase 1 only: hardcoded user ID for local stdio testing with Claude Desktop.
# Replace with your Firebase Auth uid. Phase 3 removes this in favor of real auth.
TEST_USER_ID=

# ── OAuth 2.1 (MCP Authorization spec) ────────────────────────────────────
# Required when running the HTTP transport with OAuth support.

# Public base URL of this MCP server (no trailing slash).
# Used in OAuth metadata discovery and as the JWT issuer.
MCP_SERVER_BASE_URL=https://your-mcp-server.example.com

# 256-bit secret for signing MCP access tokens (JWT).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_JWT_SECRET=

# Firebase Web API key (found in Firebase Console → Project Settings → General).
# Used to exchange Google OAuth codes for Firebase ID tokens server-side.
FIREBASE_WEB_API_KEY=
