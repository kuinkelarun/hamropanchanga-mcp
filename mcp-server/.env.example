# Firebase Admin SDK credentials — one of:
#   (a) Path to a service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
#   (b) Inline JSON (preferred for Railway / hosted deploys)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

FIREBASE_PROJECT_ID=hamropanchanga
FIREBASE_DATABASE_ID=hamropanchanga-db

# Phase 1 only: hardcoded user ID for local stdio testing with Claude Desktop.
# Replace with your Firebase Auth uid. Phase 3 removes this in favor of real auth.
TEST_USER_ID=
