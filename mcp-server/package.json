{
  "name": "hamropanchanga-mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing HamroPanchanga tools (trees, members, events, tithi, calendar, admin) to AI clients.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hamropanchanga-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/index-http.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index-http.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "express": "^4.21.0",
    "firebase-admin": "^12.7.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
