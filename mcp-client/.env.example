# =========================
# LLM provider selection
# =========================
# Pick one: "anthropic" (direct API) or "bedrock" (AWS Bedrock)
LLM_PROVIDER=anthropic

# --- If LLM_PROVIDER=anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- If LLM_PROVIDER=bedrock ---
# Uses the default AWS credential chain (env vars, ~/.aws/credentials, IAM role, etc.)
AWS_REGION=us-east-1
# Example model IDs on Bedrock — check your region's catalog for the exact id:
#   anthropic.claude-opus-4-v1:0
#   anthropic.claude-sonnet-4-v1:0
BEDROCK_MODEL=anthropic.claude-opus-4-v1:0
# Optional: explicit keys override the credential chain
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# =========================
# HTTP server
# =========================
PORT=3001

# =========================
# MCP server subprocess
# =========================
MCP_SERVER_COMMAND=node
MCP_SERVER_ARGS=../mcp-server/dist/index.js

# =========================
# Auth for the React app → chat backend link
# =========================
FIREBASE_PROJECT_ID=hamropanchanga
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Phase 1 shortcut: skip ID-token verification and use this uid directly
DEV_PASSTHROUGH_UID=
