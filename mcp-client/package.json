{
  "name": "hamropanchanga-mcp-client",
  "version": "0.1.0",
  "description": "Chat backend that connects to the HamroPanchanga MCP server and drives Claude via the Anthropic API or AWS Bedrock.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "firebase-admin": "^12.7.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
